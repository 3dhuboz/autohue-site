# AutoHue Environment Variables
# Copy this to .env and fill in your values

# ─── Nyckel AI Color Classification API ───
# Sign up at https://www.nyckel.com/ to get these credentials
# If not set, the app falls back to local LAB-only color classification
NYCKEL_CLIENT_ID=
NYCKEL_CLIENT_SECRET=
NYCKEL_FUNCTION_ID=colors-identifier

# ─── Worker Server ───
WORKER_PORT=3001
WORKER_URL=http://localhost:3001

# ─── Storage (Railway persistent volume) ───
# STORAGE_ROOT=/data

# ─── NextAuth ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/autohue

# ─── API (CF Worker) ───
NEXT_PUBLIC_API_URL=https://autohue-api.steve-700.workers.dev
WORKER_API_URL=https://autohue-api.steve-700.workers.dev

# ─── PayPal Plan IDs (monthly) ───
NEXT_PUBLIC_PAYPAL_HOBBYIST_PLAN_ID=
NEXT_PUBLIC_PAYPAL_PRO_PLAN_ID=
NEXT_PUBLIC_PAYPAL_UNLIMITED_PLAN_ID=

# ─── PayPal Plan IDs (yearly) ───
NEXT_PUBLIC_PAYPAL_HOBBYIST_YEARLY_PLAN_ID=
NEXT_PUBLIC_PAYPAL_PRO_YEARLY_PLAN_ID=
NEXT_PUBLIC_PAYPAL_UNLIMITED_YEARLY_PLAN_ID=

# ─── Resend (email) ───
RESEND_API_KEY=
